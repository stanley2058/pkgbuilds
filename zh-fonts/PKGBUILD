# Maintainer: Stanley Wang <stanley@stw.tw>

pkgname=zh-fonts
pkgver=2.100
pkgrel=1
pkgdesc='A collection of Chinese (traditional) fonts'
arch=(any)
url='https://github.com/ButTaiwan'
license=(OFL)
makedepends=(python-fonttools)
source=(
    "genyo-2.100.zip::https://github.com/ButTaiwan/genyo-font/releases/download/v2.100/GenKiMin2-ttc.zip"
    "genwan-2.100.zip::https://github.com/ButTaiwan/genwan-font/releases/download/v2.100/GenWanMin2-ttc.zip"
    "genseki-2.100.zip::https://github.com/ButTaiwan/genseki-font/releases/download/v2.100/GenSekiGothic2-ttc.zip"
    "gensen-2.100.zip::https://github.com/ButTaiwan/gensen-font/releases/download/v2.100/GenSenRounded2-ttc.zip"
    "genyog-2.100.zip::https://github.com/ButTaiwan/genyog-font/releases/download/v2.100/GenKiGothic2-ttc.zip"
)
noextract=("${source[@]%%::*}")
sha256sums=(
    "81e5ee84351102b4143bfaa2ada0f60dcd82c366c7affda293d975a63fc5742a"
    "b2e987aa451057776fbf914b05a3646433c3b81f5dad01b622fa1c0b84dfdddd"
    "a1e4a7b1e60b206451336f3c0e224f2936310cdcdb85f54a7642baba7cdd6cdf"
    "01f57ff5eac25143c654cfd37ab06d191703fb67aea94811ec48f101a2f6e203"
    "0104ba39ff119ed691e10b0da28684226928e1862058fa6096ac87e125fe31f0"
)

_fonts=('genyo' 'genwan' 'genseki' 'gensen' 'genyog')

_patch_ttc_cmap() {
    local ttc_path=$1

    python - "$ttc_path" <<'PY'
from pathlib import Path
import sys

from fontTools.ttLib import TTCollection
from fontTools.ttLib.tables._c_m_a_p import CmapSubtable

path = Path(sys.argv[1])
ttc = TTCollection(str(path))
changed = False

for font in ttc.fonts:
    format12_tables = [
        table for table in font["cmap"].tables if table.isUnicode() and table.format == 12 and table.cmap
    ]
    if not format12_tables:
        continue

    bmp_map = {
        cp: glyph
        for cp, glyph in max(format12_tables, key=lambda table: len(table.cmap)).cmap.items()
        if cp <= 0xFFFF
    }
    if not bmp_map:
        continue

    cmap_table = font["cmap"]
    for platform_id, enc_id in ((0, 3), (3, 1)):
        target = next(
            (
                table
                for table in cmap_table.tables
                if table.platformID == platform_id and table.platEncID == enc_id and table.format == 4
            ),
            None,
        )

        if target is None:
            target = CmapSubtable.newSubtable(4)
            target.platformID = platform_id
            target.platEncID = enc_id
            target.language = 0
            cmap_table.tables.append(target)

        if len(getattr(target, "cmap", {})) != len(bmp_map):
            target.cmap = dict(bmp_map)
            changed = True

if changed:
    ttc.save(str(path))
PY
}

prepare() {
    for ((i = 0; i < ${#_fonts[@]}; i++)); do
        id=${_fonts[$i]}
        dir_name=$(echo "${source[$i]}" | sed -r 's/\.zip::.*//')
        mkdir -p "$srcdir/$dir_name"
        bsdtar -xf "$dir_name.zip" -C "$srcdir/$dir_name"
        for ttc in "$srcdir/$dir_name"/*.ttc; do
            _patch_ttc_cmap "$ttc"
        done
    done
}

package() {
    for ((i = 0; i < ${#_fonts[@]}; i++)); do
        id=${_fonts[$i]}
        dir_name=$(echo "${source[$i]}" | sed -r 's/\.zip::.*//')
        cd "$srcdir/$dir_name"
        install -Dm644 -t "$pkgdir/usr/share/fonts/TTF/$id-ttf/" ./*.ttc
        install -Dm644 SIL_Open_Font_License_1.1.txt "$pkgdir/usr/share/licenses/$id-ttf/LICENSE"
    done
}
